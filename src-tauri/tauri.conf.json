{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FlowSwitch",
  "version": "0.1.1",
  "identifier": "com.kamibukuro18.flowswitch",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "FlowSwitch",
        "width": 960,
        "height": 640,
        "minWidth": 760,
        "minHeight": 500,
        "resizable": true,
        "decorations": true,
        "center": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "upgradeCode": "76da1a36-0993-5460-afb3-c8c1cc52aa12"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
